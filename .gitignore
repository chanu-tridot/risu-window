# 이 워크스페이스는 character-converter/ 만 git 에 올림.
# RisuAI 리버스 분석·로컬 추출본 등 workspace-level 자료는 전부 로컬 전용.

# 1) 루트 모든 파일·디렉토리 기본 제외
/*

# 2) 예외 — 커밋할 항목만 명시
!/.gitignore
!/CLAUDE.md
!/character-converter

# 3) character-converter/ 내부 ignore
character-converter/.env
character-converter/.venv/
character-converter/__pycache__/
character-converter/**/__pycache__/
character-converter/.pytest_cache/
character-converter/*.pyc
